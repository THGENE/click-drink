# ─────────────────────────────────────────────
# Exemple de configuration .env — Click & Drink
# ─────────────────────────────────────────────

# Serveur
PORT=4000
DB_PATH=./clickdrink.db
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Authentification JWT (OBLIGATOIRE en production) ──────────
# Générez une clé forte : openssl rand -hex 64
JWT_SECRET=remplacez_par_une_cle_tres_secrete_en_production
JWT_EXPIRES_IN=8h

# ── Sécurité création de compte vendeur ──────────────────────
# Cette clé doit être envoyée dans le header x-admin-secret
# lors de l'appel POST /vendor/register
ADMIN_SECRET=remplacez_par_un_secret_admin_fort

# ── Notifications SMS (optionnel — Twilio) ────────────────────
# Si non renseigné, la notification passe uniquement par socket
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+33600000000
BAR_CONTACT_PHONE=+33600000000

# ── Webhook d'annulation générique (optionnel) ────────────────
# URL appelée en POST quand une commande est annulée (n8n, Zapier, etc.)
CANCEL_WEBHOOK_URL=

# ── Intégration POS Square (optionnel) ───────────────────────
SQUARE_ACCESS_TOKEN=EAAAlxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=XXXXXXXXXXXX
